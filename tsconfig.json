{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@test/*": ["test/*"]
    },
  },
  "files": ["src/server.ts", "src/shared/types/fastify.d.ts"],
  "include": ["src/**/*.ts", "src/**/*.d.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"],
}
